{
  "apiType": 'stageMode',
  "buildOption": {
    "externalNativeOptions": {
      "path": "./src/main/cpp/CMakeLists.txt",
      "arguments": "-DENABLE_COMPILE_OPTIMIZATIONS=OFF -DHARMONY_NATIVE_COMPILE_JOBS=2 -DHARMONY_NATIVE_LINK_JOBS=1 -DCMAKE_JOB_POOLS=compile_pool=2;link_pool=1 -DCMAKE_JOB_POOL_COMPILE=compile_pool -DCMAKE_JOB_POOL_LINK=link_pool",
      "abiFilters": ["x86_64"],
    },
  },
  "targets": [
    {
      "name": "default",
      "runtimeOS": "HarmonyOS"
    },
    {
      "name": "ohosTest",
    }
  ]
}
