{
  // build-profile.json5 can contain signingConfigs which are unique for each developer, therefore that file is ignored by Git. Copy this template to build-profile.json5 after cloning to open the Harmony project in DevEco Studio.
  app: {
    products: [
      {
        name: 'default',
        signingConfig: 'default',
        compatibleSdkVersion: '5.0.0(12)',
        targetSdkVersion: '6.0.0(20)',
        runtimeOS: 'HarmonyOS',
        buildOption: {
          nativeCompiler: 'BiSheng'
        }
      },
    ],
    buildModeSet: [
      {
        name: 'debug',
      },
      {
        name: 'release',
      },
    ],
    signingConfigs: [],
  },
  modules: [
    {
      name: 'entry',
      srcPath: './entry',
      targets: [
        {
          name: 'default',
          applyToProducts: ['default'],
        },
      ],
    },
  ],
}

