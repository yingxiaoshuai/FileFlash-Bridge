# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'FileFlashBridge' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Xcode 26 can compile the app target before CocoaPods copies the
    # document-picker modulemap into BUILT_PRODUCTS_DIR, which leaves the app
    # pointing at a transient missing file under DerivedData. Use the stable
    # public header modulemap instead.
    support_files = File.join(__dir__, 'Pods', 'Target Support Files', 'Pods-FileFlashBridge')
    source_modulemap = '${PODS_ROOT}/Headers/Public/react_native_document_picker/react-native-document-picker.modulemap'
    generated_modulemap = '${PODS_CONFIGURATION_BUILD_DIR}/react-native-document-picker/react_native_document_picker.modulemap'

    %w[debug release].each do |configuration|
      xcconfig_path = File.join(support_files, "Pods-FileFlashBridge.#{configuration}.xcconfig")
      next unless File.exist?(xcconfig_path)

      xcconfig = File.read(xcconfig_path)
      next unless xcconfig.include?(generated_modulemap)

      File.write(xcconfig_path, xcconfig.gsub(generated_modulemap, source_modulemap))
    end
  end
end
